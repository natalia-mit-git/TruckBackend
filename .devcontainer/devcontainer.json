{
  "name": "TruckBackend Dev",

  "dockerComposeFile": "dev-docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/dotnet:1": {
      "version": "8.0"
    }
  },

  "mounts": [
    "source=${env:SSH_AUTH_SOCK},target=/ssh-agent,type=bind"
  ],

  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/root/.dotnet/tools",
    "SSH_AUTH_SOCK": "/ssh-agent"
  },

  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y openssh-client && dotnet restore && dotnet tool install --global dotnet-ef",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "editorconfig.editorconfig"
      ]
    }
  }
}
